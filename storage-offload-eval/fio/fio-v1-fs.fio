; FIO configuration: vLLM v1 filesystem KV cache offload connector
;
; Characterises storage suitability for the vLLM v1 fs connector
; (vllm/v1/kv_offload/tiering/fs/io.py).
;
; I/O MODEL:
;   O_DIRECT, one os.write() per GPU KV block, one file per job.
;   Block sizes match actual GPU KV cache block sizes (TP=2, BF16 KV):
;     Qwen3-8B:        ~256 KB
;     gpt-oss-120b:    ~576 KB  (MoE, 36 layers)
;     FP8-70B/BF16-70B: ~5 MB  (80 layers)
;
; USAGE:
;   fio fio-v1-fs.fio --directory=/path/to/test/storage
;
; REQUIREMENTS:
;   - Storage must be mounted at --directory
;   - Each job creates its own 2 GiB file; max 16 jobs = 32 GiB required
;   - fio >= 3.x
;
; PRIMARY METRIC: lat_ns.percentile (p50, p99)
;   A block load is on the critical path before the first inference token.
;   Acceptable p99 < 20 ms at j=16 for large models.
;
; See REPORT.md for full methodology and interpretation guide.
; Reference data (single Micron 7450 NVMe / XFS):
;   FP8-70B read  j=1:  p99 = 1.3 ms
;   FP8-70B read  j=16: p99 = 14.1 ms   <- Good tier
;   gpt-120b read j=16: p99 = 2.8 ms    <- Excellent tier

[global]
direct=1
ioengine=libaio
iodepth=1
size=2G
runtime=60
time_based=1
group_reporting=1
lat_percentiles=1
output-format=json+

; ── Qwen3-8B block size: ~256 KB ─────────────────────────────────────────────
; 28 layers × 4 KV heads/rank × 128 head_dim × 2 × 2 B × 16 tok × 2 ranks

[qwen8b-write-j1]
rw=write
bs=256k
numjobs=1
stonewall

[qwen8b-read-j1]
rw=read
bs=256k
numjobs=1
stonewall

[qwen8b-write-j16]
rw=write
bs=256k
numjobs=16
stonewall

[qwen8b-read-j16]
rw=read
bs=256k
numjobs=16
stonewall

; ── gpt-oss-120b block size: ~576 KB ─────────────────────────────────────────
; 36 layers × 4 KV heads/rank × 64 head_dim × 2 × 2 B × 16 tok × 2 ranks

[gpt120b-write-j1]
rw=write
bs=576k
numjobs=1
stonewall

[gpt120b-read-j1]
rw=read
bs=576k
numjobs=1
stonewall

[gpt120b-write-j16]
rw=write
bs=576k
numjobs=16
stonewall

[gpt120b-read-j16]
rw=read
bs=576k
numjobs=16
stonewall

; ── FP8-70B / BF16-70B block size: ~5 MB ────────────────────────────────────
; 80 layers × 4 KV heads/rank × 128 head_dim × 2 × 2 B × 16 tok × 2 ranks
; = 5,242,880 bytes. Aligned to XFS sunit (1 MiB) on typical LVMS/topolvm setups.

[fp8-70b-write-j1]
rw=write
bs=5m
numjobs=1
stonewall

[fp8-70b-read-j1]
rw=read
bs=5m
numjobs=1
stonewall

[fp8-70b-write-j16]
rw=write
bs=5m
numjobs=16
stonewall

[fp8-70b-read-j16]
rw=read
bs=5m
numjobs=16
stonewall

; ── Mixed RW: steady-state eviction + restoration ────────────────────────────
; Models simultaneous block evictions and cache restorations at full concurrency.

[fp8-70b-mixed-j16]
rw=rw
bs=5m
numjobs=16
stonewall
