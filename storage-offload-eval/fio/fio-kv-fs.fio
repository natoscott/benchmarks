; FIO configuration: vLLM KV cache filesystem offload connector
;
; Characterises storage suitability for the vLLM native fs offload connector
; (vllm/v1/kv_offload/tiering/fs/io.py, vLLM 0.22.0+).
;
; I/O MODEL:
;   O_DIRECT, one os.write() per GPU KV block, one file per job.
;   Block sizes match actual GPU KV cache block sizes (TP=2, BF16 KV):
;     Qwen3-8B:         ~2.25 MB (2304k)  36 layers × 8 KV heads × head_dim=128
;     gpt-oss-120b:     ~576 KB           MoE, 36 layers × 4 KV heads × head_dim=64
;     FP8-70B/BF16-70B: ~5 MB            80 layers × 8 KV heads × head_dim=128
;
; USAGE:
;   fio fio-kv-fs.fio --directory=/path/to/test/storage --output-format=json+ --output=results.json
;   jq '[.jobs[] | select(.jobname | test("read-j16")) | {job: .jobname, p99_ms: (.read.lat_ns.percentile["99.000000"] / 1e6)}]' results.json
;
; REQUIREMENTS:
;   - Storage must be mounted at --directory
;   - ~15 GiB free space required (read/mixed sections reuse write files)
;   - fio >= 3.x
;
; PRIMARY METRIC: lat_ns.percentile (p50, p99) on *-read-j16 sections.
;   A block load is on the critical path before the first inference token.
;   Acceptable p99 < 20 ms at j=16 for large models.
;
; MIXED TEST (rwmixread=75):
;   Approximates steady-state prefix-cache workload: 75% reads (cache restores)
;   25% writes (evictions). Ratio reflects high-hit-rate serving; adjust
;   rwmixread downward for low-prefix-cache or eviction-heavy workloads.
;
; See REPORT.md for full methodology and interpretation guide.
; Reference data (single Micron 7450 NVMe / XFS):
;   FP8-70B  read  j=16: p99 = 14.1 ms   <- Good tier
;   gpt-120b read  j=16: p99 = 2.8 ms    <- Excellent tier
;   Qwen3-8B read  j=16: p99 = 2.3 ms    <- Excellent tier

[global]
direct=1
ioengine=libaio
iodepth=1
; size=225m is divisible by all block sizes used here (2304k, 576k, 5m).
; Read and mixed sections share filenames with their write counterparts
; so total disk use is ~15 GiB across all sections, not 16 × size per section.
size=225m
runtime=60
time_based=1
group_reporting=1
lat_percentiles=1

; ── Qwen3-8B block size: ~2.25 MB ────────────────────────────────────────────
; 36 layers × 4 KV heads/rank × 128 head_dim × 2 × 2 B × 16 tok × 2 ranks
; = 2,359,296 bytes = 2304 KiB

[qwen8b-write-j1]
rw=write
bs=2304k
numjobs=1
filename_format=qwen8b-j1.$jobnum.dat
stonewall

[qwen8b-read-j1]
rw=read
bs=2304k
numjobs=1
filename_format=qwen8b-j1.$jobnum.dat
stonewall

[qwen8b-write-j16]
rw=write
bs=2304k
numjobs=16
filename_format=qwen8b-j16.$jobnum.dat
stonewall

[qwen8b-read-j16]
rw=read
bs=2304k
numjobs=16
filename_format=qwen8b-j16.$jobnum.dat
stonewall

[qwen8b-mixed-j16]
rw=randrw
rwmixread=75
bs=2304k
numjobs=16
filename_format=qwen8b-j16.$jobnum.dat
stonewall

; ── gpt-oss-120b block size: ~576 KB ─────────────────────────────────────────
; 36 layers × 4 KV heads/rank × 64 head_dim × 2 × 2 B × 16 tok × 2 ranks

[gpt120b-write-j1]
rw=write
bs=576k
numjobs=1
filename_format=gpt120b-j1.$jobnum.dat
stonewall

[gpt120b-read-j1]
rw=read
bs=576k
numjobs=1
filename_format=gpt120b-j1.$jobnum.dat
stonewall

[gpt120b-write-j16]
rw=write
bs=576k
numjobs=16
filename_format=gpt120b-j16.$jobnum.dat
stonewall

[gpt120b-read-j16]
rw=read
bs=576k
numjobs=16
filename_format=gpt120b-j16.$jobnum.dat
stonewall

[gpt120b-mixed-j16]
rw=randrw
rwmixread=75
bs=576k
numjobs=16
filename_format=gpt120b-j16.$jobnum.dat
stonewall

; ── FP8-70B / BF16-70B block size: ~5 MB ────────────────────────────────────
; 80 layers × 4 KV heads/rank × 128 head_dim × 2 × 2 B × 16 tok × 2 ranks
; = 5,242,880 bytes. Aligned to XFS sunit (1 MiB) on typical LVMS/topolvm setups.

[fp8-70b-write-j1]
rw=write
bs=5m
numjobs=1
filename_format=fp8-70b-j1.$jobnum.dat
stonewall

[fp8-70b-read-j1]
rw=read
bs=5m
numjobs=1
filename_format=fp8-70b-j1.$jobnum.dat
stonewall

[fp8-70b-write-j16]
rw=write
bs=5m
numjobs=16
filename_format=fp8-70b-j16.$jobnum.dat
stonewall

[fp8-70b-read-j16]
rw=read
bs=5m
numjobs=16
filename_format=fp8-70b-j16.$jobnum.dat
stonewall

; ── Mixed RW: steady-state eviction + restoration (75% read / 25% write) ─────
; Approximates prefix-cache-heavy serving: blocks written once on eviction,
; read back multiple times on cache hit. Adjust rwmixread for your workload.

[fp8-70b-mixed-j16]
rw=randrw
rwmixread=75
bs=5m
numjobs=16
filename_format=fp8-70b-j16.$jobnum.dat
stonewall
